generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id          String          @id @default(uuid())
  email       String          @unique
  password    String
  role        String          @default("customer")
  name        String?
  phone       String?
  current_lat Float?
  current_lng Float?
  shifts      Shift[]
  shipments   Shipment[]      @relation("OperatorShipments")
  tickets     SupportTicket[]
}

model SupportTicket {
  id         String          @id @default(uuid())
  user_id    String
  subject    String
  status     String          @default("OPEN")
  priority   String          @default("MEDIUM")
  created_at DateTime        @default(now())
  user       User            @relation(fields: [user_id], references: [id])
  messages   TicketMessage[]
}

model TicketMessage {
  id        Int           @id @default(autoincrement())
  ticket_id String
  sender_id String
  text      String
  timestamp DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticket_id], references: [id])
}

model DirectMessage {
  id          Int      @id @default(autoincrement())
  sender_id   String
  receiver_id String
  text        String
  timestamp   DateTime @default(now())
}

model Shipment {
  id                 String            @id
  sender_name        String?
  sender_city        String?
  sender_country     String?
  sender_address     String?
  receiver_name      String?
  receiver_city      String?
  receiver_country   String?
  receiver_address   String?
  receiver_phone     String?
  receiver_email     String?
  status             String?
  weight             Float?
  type               String?
  est_delivery       String?
  estimated_cost     Float?
  insurance_selected Boolean?
  package_details    String?
  operator_id        String?
  created_at         DateTime?         @default(now())
  customs_docs       CustomsDoc[]
  notification_logs  NotificationLog[]
  operator           User?             @relation("OperatorShipments", fields: [operator_id], references: [id])
  tracking_updates   TrackingUpdate[]
}

model TrackingUpdate {
  id          Int       @id @default(autoincrement())
  shipment_id String?
  status      String?
  location    String?
  notes       String?
  timestamp   DateTime? @default(now())
  shipment    Shipment? @relation(fields: [shipment_id], references: [id])
}

model CustomsDoc {
  id          Int       @id @default(autoincrement())
  shipment_id String?
  doc_type    String?
  status      String?
  file_url    String?
  uploaded_at DateTime?
  shipment    Shipment? @relation(fields: [shipment_id], references: [id])
}

model NotificationLog {
  id          Int       @id @default(autoincrement())
  user_id     String?
  shipment_id String?
  channel     String?
  message     String?
  status      String?
  timestamp   DateTime? @default(now())
  shipment    Shipment? @relation(fields: [shipment_id], references: [id])
}

model Setting {
  key   String  @id
  value String?
}

model Shift {
  id         Int       @id @default(autoincrement())
  user_id    String
  start_time DateTime  @default(now())
  end_time   DateTime?
  user       User      @relation(fields: [user_id], references: [id])
}
